APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Для php artisan serve по HTTP: false, иначе кука сессии Secure и CSRF ломается на 127.0.0.1
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreplay@reprobad.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PAGINATION_LIMIT=20

# Web Bot Auth (draft-meunier-http-message-signatures-directory)
# Generate with: php artisan tinker --execute="echo base64_encode(sodium_crypto_sign_secretkey(sodium_crypto_sign_keypair()));"
WEBBOT_SIGNING_KEY=

# HydraAI API (https://hydraai.ru) — основной ключ
AI_TOKEN=
# Альтернатива, если не задан AI_TOKEN:
# HYDRA_AI_KEY=
# Модель (список в кабинете HydraAI / документации). По умолчанию:
# HYDRA_AI_MODEL=deepseek-v3.2

# Telegram-бот (webhook и исходящие сообщения)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# Прокси для исходящих вызовов api.telegram.org (см. https://api.dashboard.proxy.market/docs — ip + http_port из POST /dev-api/list/{api_key})
# Вариант 1 — одна строка:
# TELEGRAM_HTTP_PROXY=http://USER:PASS@HOST:PORT
# Вариант 2 — отдельно (удобно, если в пароле спецсимволы):
# TELEGRAM_PROXY_HOST=
# TELEGRAM_PROXY_PORT=
# TELEGRAM_PROXY_USER=
# TELEGRAM_PROXY_PASSWORD=
