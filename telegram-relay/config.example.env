# Скопируйте в .env на VPS-реле (файл не коммитить).

# Токен бота (только на реле; на РЕПРО можно убрать после перехода на реле).
TELEGRAM_BOT_TOKEN=

# Тот же секрет, что в BotFather → setWebhook → secret_token, и заголовок от Telegram на реле.
TELEGRAM_WEBHOOK_SECRET=

# Полный URL процессора на РЕПРО (HTTPS, доступен с VPS реле).
REPRO_RELAY_URL=https://reprobad.com/api/telegram/relay/process

# Тот же секрет, что TELEGRAM_RELAY_INBOUND_SECRET в .env на РЕПРО.
REPRO_RELAY_SECRET=

# Таймаут запроса к РЕПРО (сек), с запасом под AI.
REPRO_HTTP_TIMEOUT=120
